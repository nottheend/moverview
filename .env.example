# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Docker / Registry ─────────────────────────────────────────────────────────
# Your Cloudron's built-in registry domain.
# Find it: Cloudron Admin → App Store → gear icon (top right) → Registry
CLOUDRON_REGISTRY=registry.your-cloudron.example.com
IMAGE_NAME=firefly-dashboard

# ── Cloudron app location ─────────────────────────────────────────────────────
CLOUDRON_APP=firefly-ui
CLOUDRON_HOST=your-cloudron.example.com

# ── Server env vars (local dev only) ─────────────────────────────────────────
# On Cloudron these are set via the app's Settings → Environment Variables UI.
FIREFLY_BASE_URL=https://firefly.your-cloudron.example.com
FIREFLY_TOKEN=your-firefly-personal-access-token
SESSION_SECRET=change-me-run-openssl-rand-hex-32
NODE_ENV=development
